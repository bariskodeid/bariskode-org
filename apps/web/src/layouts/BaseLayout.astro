---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bariskode — Learn. Hack. Certify.',
  description = 'Platform pembelajaran pemrograman & cybersecurity open source. Belajar coding, CTF challenges, dan dapatkan sertifikat terverifikasi.',
} = Astro.props;

const user = Astro.locals.user;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- OG Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <title>{title}</title>
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Navbar -->
    <nav class="glass sticky top-0 z-50 border-b border-[var(--color-border)]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2 no-underline">
            <span class="text-[var(--color-primary)] font-mono font-bold text-xl tracking-tight">
              &lt;bariskode/&gt;
            </span>
          </a>

          <!-- Nav Links -->
          <div class="hidden md:flex items-center gap-6">
            <a
              href="/courses"
              class="text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors text-sm font-medium"
            >
              Courses
            </a>
            <a
              href="/playground"
              class="text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors text-sm font-medium"
            >
              Playground
            </a>
            <a
              href="/ctf"
              class="text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors text-sm font-medium"
            >
              CTF
            </a>
          </div>

          <!-- Auth -->
          <div class="flex items-center gap-3">
            {user ? (
              <div class="flex items-center gap-3">
                <a
                  href="/dashboard"
                  class="text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors text-sm font-medium"
                >
                  Dashboard
                </a>
                <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)]">
                  <span class="w-2 h-2 rounded-full bg-[var(--color-primary)]" />
                  <span class="text-sm font-mono text-[var(--color-text)]">{user.username}</span>
                </div>
              </div>
            ) : (
              <>
                <a
                  href="/login"
                  class="text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors text-sm font-medium"
                >
                  Login
                </a>
                <a
                  href="/register"
                  class="inline-flex items-center px-4 py-2 text-sm font-semibold text-[var(--color-bg)] bg-[var(--color-primary)] rounded-lg hover:bg-[var(--color-primary-dim)] transition-all duration-200"
                >
                  Daftar Gratis
                </a>
              </>
            )}
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Brand -->
          <div class="md:col-span-2">
            <span class="text-[var(--color-primary)] font-mono font-bold text-lg">&lt;bariskode/&gt;</span>
            <p class="mt-3 text-sm text-[var(--color-muted)] max-w-md">
              Platform pembelajaran pemrograman & cybersecurity open source.
              Learn. Hack. Certify. — Gratis dan sepenuhnya open source.
            </p>
            <div class="flex gap-4 mt-4">
              <a href="https://github.com/bariskode-org" target="_blank" rel="noopener"
                class="text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
            </div>
          </div>

          <!-- Links -->
          <div>
            <h4 class="text-sm font-semibold text-[var(--color-text)] mb-3">Platform</h4>
            <ul class="space-y-2 text-sm text-[var(--color-muted)]">
              <li><a href="/courses" class="hover:text-[var(--color-primary)] transition-colors">Courses</a></li>
              <li><a href="/playground" class="hover:text-[var(--color-primary)] transition-colors">Playground</a></li>
              <li><a href="/ctf" class="hover:text-[var(--color-primary)] transition-colors">CTF Challenges</a></li>
            </ul>
          </div>

          <div>
            <h4 class="text-sm font-semibold text-[var(--color-text)] mb-3">Open Source</h4>
            <ul class="space-y-2 text-sm text-[var(--color-muted)]">
              <li><a href="https://github.com/bariskode-org" target="_blank" class="hover:text-[var(--color-primary)] transition-colors">GitHub</a></li>
              <li><a href="/docs" class="hover:text-[var(--color-primary)] transition-colors">Docs</a></li>
              <li><a href="/verify" class="hover:text-[var(--color-primary)] transition-colors">Verify Certificate</a></li>
            </ul>
          </div>
        </div>

        <div class="mt-8 pt-6 border-t border-[var(--color-border)]">
          <p class="text-xs text-[var(--color-muted)] text-center">
            © {new Date().getFullYear()} Bariskode. Open source under MIT License.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
