---
import type { Course } from "../types/index";

interface Props {
    course: Course;
    progress?: number;
}

const { course, progress } = Astro.props;

const difficultyLabel: Record<string, string> = {
    beginner: "Pemula",
    intermediate: "Menengah",
    advanced: "Lanjutan",
};

const difficultyStyle: Record<string, string> = {
    beginner: "color: #22c55e; border-color: #22c55e;",
    intermediate: "color: #eab308; border-color: #eab308;",
    advanced: "color: #ef4444; border-color: #ef4444;",
};

const pbUrl = import.meta.env.PUBLIC_POCKETBASE_URL ?? "http://localhost:8090";
const thumbnailUrl = course.thumbnail
    ? `${pbUrl}/api/files/courses/${course.id}/${course.thumbnail}`
    : null;
---

<a
    href={`/courses/${course.slug}`}
    class="group block rounded-2xl border border-[var(--color-border)] overflow-hidden transition-all duration-300 hover:border-[var(--color-primary)]/50 hover:shadow-lg hover:shadow-[var(--color-primary)]/5"
    style="background-color: var(--color-surface);"
>
    <!-- Thumbnail -->
    {
        thumbnailUrl ? (
            <div class="w-full h-44 overflow-hidden">
                <img
                    src={thumbnailUrl}
                    alt={course.title}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
            </div>
        ) : (
            <div
                class="w-full h-44 flex items-center justify-center"
                style="background-color: var(--color-surface-alt);"
            >
                <span class="text-4xl font-mono font-bold text-[var(--color-border)]">
                    &lt;/&gt;
                </span>
            </div>
        )
    }

    <!-- Content -->
    <div class="p-5">
        <!-- Tags Row -->
        <div class="flex items-center gap-2 mb-3 flex-wrap">
            <span
                class="text-[10px] font-mono font-bold uppercase tracking-wider px-2 py-0.5 rounded-md border"
                style={difficultyStyle[course.difficulty]}
            >
                {difficultyLabel[course.difficulty] ?? course.difficulty}
            </span>
            {
                course.expand?.category && (
                    <span class="text-[11px] text-[var(--color-muted)] font-medium">
                        {course.expand.category.icon}{" "}
                        {course.expand.category.name}
                    </span>
                )
            }
        </div>

        <!-- Title -->
        <h3
            class="text-base font-bold text-[var(--color-text)] mb-1.5 line-clamp-2 group-hover:text-[var(--color-primary)] transition-colors"
        >
            {course.title}
        </h3>

        <!-- Description -->
        <p class="text-sm text-[var(--color-muted)] line-clamp-2 mb-3">
            {course.description}
        </p>

        <!-- Meta -->
        <div class="flex items-center gap-4 text-xs text-[var(--color-muted)]">
            {
                (course.estimated_hours ?? 0) > 0 && (
                    <span class="flex items-center gap-1">
                        <svg
                            class="w-3.5 h-3.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                            />
                        </svg>
                        {course.estimated_hours}j
                    </span>
                )
            }
            {
                course.total_lessons > 0 && (
                    <span class="flex items-center gap-1">
                        <svg
                            class="w-3.5 h-3.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                            />
                        </svg>
                        {course.total_lessons} lesson
                    </span>
                )
            }
            {
                course.enrolled_count > 0 && (
                    <span class="flex items-center gap-1">
                        <svg
                            class="w-3.5 h-3.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
                            />
                        </svg>
                        {course.enrolled_count}
                    </span>
                )
            }
        </div>

        <!-- Progress Bar -->
        {
            progress !== undefined && progress > 0 && (
                <div class="mt-4">
                    <div class="flex justify-between text-xs text-[var(--color-muted)] mb-1">
                        <span>Progress</span>
                        <span class="font-mono">{progress}%</span>
                    </div>
                    <div
                        class="h-1.5 rounded-full"
                        style="background-color: var(--color-border);"
                    >
                        <div
                            class="h-full rounded-full transition-all duration-500"
                            style={`width: ${progress}%; background-color: var(--color-primary);`}
                        />
                    </div>
                </div>
            )
        }
    </div>
</a>
