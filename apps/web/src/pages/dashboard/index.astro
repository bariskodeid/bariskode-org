---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CourseCard from "../../components/CourseCard.astro";
import type { Course } from "../../types/index";

const { pb, user } = Astro.locals;
if (!user) return Astro.redirect("/login?redirect=/dashboard");

// Refresh user data
let userData: any = user;
try {
    userData = await pb.collection("users").getOne(user.id);
} catch {}

const level = userData.level ?? 1;
const xp = userData.xp ?? 0;
const xpForNextLevel = level * 100;
const xpProgress = Math.min(
    Math.round(((xp % 100) / xpForNextLevel) * 100),
    100,
);
const streakCurrent = userData.streak_current ?? 0;
const streakLongest = userData.streak_longest ?? 0;

// Fetch all user progress
let progressRecords: any[] = [];
try {
    progressRecords = await pb.collection("user_progress").getFullList({
        filter: `user = '${user.id}'`,
    });
} catch {}

const completedLessons = progressRecords.filter(
    (p) => p.status === "completed",
);

// Get unique lesson IDs → modules → courses for active courses
let activeCourses: { course: Course; completed: number; total: number }[] = [];
try {
    if (progressRecords.length > 0) {
        const lessonIds = [...new Set(progressRecords.map((p) => p.lesson))];
        const lessons = await pb.collection("lessons").getFullList({
            filter: lessonIds.map((id) => `id = '${id}'`).join(" || "),
        });

        const moduleIds = [...new Set(lessons.map((l: any) => l.module))];
        if (moduleIds.length > 0) {
            const modules = await pb.collection("modules").getFullList({
                filter: moduleIds.map((id) => `id = '${id}'`).join(" || "),
            });

            const courseIds = [...new Set(modules.map((m: any) => m.course))];
            if (courseIds.length > 0) {
                const courses = await pb
                    .collection("courses")
                    .getFullList<Course>({
                        filter: courseIds
                            .map((id) => `id = '${id}'`)
                            .join(" || "),
                        expand: "category",
                    });

                // For each course, count completed vs total published lessons
                for (const course of courses) {
                    const courseModules = modules.filter(
                        (m: any) => m.course === course.id,
                    );
                    const courseModuleIds = courseModules.map((m: any) => m.id);
                    const courseLessons = await pb
                        .collection("lessons")
                        .getFullList({
                            filter:
                                courseModuleIds
                                    .map((id) => `module = '${id}'`)
                                    .join(" || ") + " && status = 'published'",
                        });
                    const completedIds = new Set(
                        completedLessons.map((p) => p.lesson),
                    );
                    const completedInCourse = courseLessons.filter((l: any) =>
                        completedIds.has(l.id),
                    ).length;
                    activeCourses.push({
                        course,
                        completed: completedInCourse,
                        total: courseLessons.length,
                    });
                }
            }
        }
    }
} catch {}

// Fetch recommended courses (published, not yet started)
let recommended: Course[] = [];
try {
    const activeCourseIds = activeCourses.map((ac) => ac.course.id);
    const result = await pb.collection("courses").getList<Course>(1, 6, {
        filter:
            "status = 'published'" +
            (activeCourseIds.length > 0
                ? ` && ${activeCourseIds.map((id) => `id != '${id}'`).join(" && ")}`
                : ""),
        sort: "-created",
        expand: "category",
    });
    recommended = result.items;
} catch {}

// Recent activity (last 5 completed lessons)
let recentActivity: { title: string; completedAt: string; lessonId: string }[] =
    [];
try {
    const recentCompleted = completedLessons.slice(0, 5);
    for (const p of recentCompleted) {
        try {
            const lesson = await pb.collection("lessons").getOne(p.lesson);
            recentActivity.push({
                title: lesson.title,
                completedAt: p.completed_at ?? p.updated,
                lessonId: p.lesson,
            });
        } catch {}
    }
} catch {}
---

<BaseLayout
    title="Dashboard — Bariskode"
    description="Dashboard belajarmu di Bariskode."
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1
                    class="text-2xl sm:text-3xl font-bold text-[var(--color-text)]"
                >
                    Halo, <span class="text-[var(--color-primary)]"
                        >{userData.username}</span
                    >! 👋
                </h1>
                <p class="text-[var(--color-muted)] mt-1">
                    Melanjutkan perjalanan belajarmu.
                </p>
            </div>
            <a
                href="/api/auth/logout"
                class="h-10 px-4 rounded-xl border border-[var(--color-border)] text-sm font-medium text-[var(--color-muted)] hover:border-red-500/50 hover:text-red-400 transition-all flex items-center gap-2"
                style="background-color: var(--color-surface);"
            >
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
                    ></path></svg
                >
                Logout
            </a>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
            <!-- Level -->
            <div
                class="rounded-xl border border-[var(--color-border)] p-5"
                style="background-color: var(--color-surface);"
            >
                <div
                    class="text-xs text-[var(--color-muted)] font-mono uppercase tracking-wider mb-2"
                >
                    Level
                </div>
                <div
                    class="text-3xl font-black text-[var(--color-primary)] font-mono"
                >
                    {level}
                </div>
                <div class="mt-3">
                    <div
                        class="flex justify-between text-[10px] text-[var(--color-muted)] mb-1"
                    >
                        <span>XP</span>
                        <span>{xp % 100}/{xpForNextLevel}</span>
                    </div>
                    <div
                        class="h-1.5 rounded-full"
                        style="background-color: var(--color-border);"
                    >
                        <div
                            class="h-full rounded-full transition-all"
                            style={`width: ${xpProgress}%; background-color: var(--color-primary);`}
                        >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Total XP -->
            <div
                class="rounded-xl border border-[var(--color-border)] p-5"
                style="background-color: var(--color-surface);"
            >
                <div
                    class="text-xs text-[var(--color-muted)] font-mono uppercase tracking-wider mb-2"
                >
                    Total XP
                </div>
                <div
                    class="text-3xl font-black text-[var(--color-accent)] font-mono"
                >
                    {xp.toLocaleString()}
                </div>
                <div class="text-xs text-[var(--color-muted)] mt-3">
                    Lifetime points
                </div>
            </div>

            <!-- Streak -->
            <div
                class="rounded-xl border border-[var(--color-border)] p-5"
                style="background-color: var(--color-surface);"
            >
                <div
                    class="text-xs text-[var(--color-muted)] font-mono uppercase tracking-wider mb-2"
                >
                    Streak
                </div>
                <div
                    class="text-3xl font-black text-[var(--color-warning)] font-mono"
                >
                    {streakCurrent}🔥
                </div>
                <div class="text-xs text-[var(--color-muted)] mt-3">
                    Terpanjang: {streakLongest} hari
                </div>
            </div>

            <!-- Completed -->
            <div
                class="rounded-xl border border-[var(--color-border)] p-5"
                style="background-color: var(--color-surface);"
            >
                <div
                    class="text-xs text-[var(--color-muted)] font-mono uppercase tracking-wider mb-2"
                >
                    Lesson Selesai
                </div>
                <div
                    class="text-3xl font-black text-[var(--color-info)] font-mono"
                >
                    {completedLessons.length}
                </div>
                <div class="text-xs text-[var(--color-muted)] mt-3">
                    Total selesai
                </div>
            </div>
        </div>

        <!-- Active Courses -->
        {
            activeCourses.length > 0 && (
                <section class="mb-10">
                    <h2 class="text-xl font-bold text-[var(--color-text)] mb-5">
                        Kursus Aktif
                    </h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                        {activeCourses.map(({ course, completed, total }) => {
                            const pct =
                                total > 0
                                    ? Math.round((completed / total) * 100)
                                    : 0;
                            return (
                                <CourseCard course={course} progress={pct} />
                            );
                        })}
                    </div>
                </section>
            )
        }

        <!-- Recent Activity -->
        {
            recentActivity.length > 0 && (
                <section class="mb-10">
                    <h2 class="text-xl font-bold text-[var(--color-text)] mb-5">
                        Aktivitas Terbaru
                    </h2>
                    <div
                        class="rounded-xl border border-[var(--color-border)] divide-y divide-[var(--color-border)] overflow-hidden"
                        style="background-color: var(--color-surface);"
                    >
                        {recentActivity.map((activity) => (
                            <a
                                href={`/learn/${activity.lessonId}`}
                                class="flex items-center justify-between px-5 py-3.5 hover:bg-[var(--color-surface-alt)]/50 transition-colors"
                            >
                                <div class="flex items-center gap-3">
                                    <span
                                        class="flex items-center justify-center w-7 h-7 rounded-full text-xs"
                                        style="background-color: var(--color-primary); color: var(--color-bg);"
                                    >
                                        ✓
                                    </span>
                                    <span class="text-sm text-[var(--color-text)]">
                                        {activity.title}
                                    </span>
                                </div>
                                <span class="text-xs text-[var(--color-muted)] shrink-0">
                                    {new Date(
                                        activity.completedAt,
                                    ).toLocaleDateString("id-ID", {
                                        day: "numeric",
                                        month: "short",
                                    })}
                                </span>
                            </a>
                        ))}
                    </div>
                </section>
            )
        }

        <!-- Recommended -->
        {
            recommended.length > 0 && (
                <section>
                    <div class="flex items-center justify-between mb-5">
                        <h2 class="text-xl font-bold text-[var(--color-text)]">
                            Rekomendasi Kursus
                        </h2>
                        <a
                            href="/courses"
                            class="text-sm text-[var(--color-primary)] hover:underline"
                        >
                            Lihat semua →
                        </a>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                        {recommended.map((course) => (
                            <CourseCard course={course} />
                        ))}
                    </div>
                </section>
            )
        }

        <!-- Empty State -->
        {
            activeCourses.length === 0 && recommended.length === 0 && (
                <div class="text-center py-16">
                    <div class="text-5xl mb-4">🚀</div>
                    <h3 class="text-lg font-bold text-[var(--color-text)] mb-2">
                        Mulai Perjalanan Belajarmu
                    </h3>
                    <p class="text-sm text-[var(--color-muted)] mb-6">
                        Jelajahi kursus yang tersedia dan mulai belajar
                        sekarang.
                    </p>
                    <a
                        href="/courses"
                        class="inline-flex items-center h-11 px-6 rounded-xl text-sm font-bold"
                        style="background-color: var(--color-primary); color: var(--color-bg);"
                    >
                        Jelajahi Kursus
                    </a>
                </div>
            )
        }
    </div>
</BaseLayout>
