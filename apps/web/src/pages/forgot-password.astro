---
import BaseLayout from "../layouts/BaseLayout.astro";

let error = "";
let success = "";

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const email = formData.get("email")?.toString().trim() ?? "";

        if (!email) {
            error = "Email wajib diisi.";
        } else {
            const pb = Astro.locals.pb;
            await pb.collection("users").requestPasswordReset(email);
            success =
                "Link reset password telah dikirim ke email kamu. Cek inbox atau folder spam.";
        }
    } catch (e: any) {
        success = "Jika email terdaftar, link reset password akan dikirim.";
    }
}
---

<BaseLayout
    title="Lupa Password — Bariskode"
    description="Reset password akun Bariskode."
>
    <section
        class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12"
    >
        <div class="w-full max-w-[440px]">
            <!-- Card Container -->
            <div
                class="rounded-2xl border border-[var(--color-border)] backdrop-blur-xl p-12 shadow-2xl shadow-black/20"
                style="background-color: color-mix(in srgb, var(--color-surface) 90%, transparent);"
            >
                <!-- Header -->
                <div class="text-center mb-8">
                    <a
                        href="/"
                        class="inline-block text-[var(--color-primary)] font-mono font-bold text-xl hover:opacity-80 transition-opacity"
                        >&lt;bariskode/&gt;</a
                    >
                    <h1
                        class="text-2xl font-bold text-[var(--color-text)] mt-3"
                    >
                        Lupa Password
                    </h1>
                    <p class="text-sm text-[var(--color-muted)] mt-1">
                        Masukkan email akunmu dan kami akan mengirim link reset.
                    </p>
                </div>

                <!-- Error Banner -->
                {
                    error && (
                        <div class="mb-5 px-4 py-3 rounded-xl border border-red-500/30 bg-red-500/10 text-sm text-red-400 flex items-center gap-2">
                            <svg
                                class="w-4 h-4 shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                />
                            </svg>
                            {error}
                        </div>
                    )
                }

                <!-- Success Banner -->
                {
                    success && (
                        <div class="mb-5 px-4 py-3 rounded-xl border border-[var(--color-primary)]/30 bg-[var(--color-primary)]/10 text-sm text-[var(--color-primary)] flex items-center gap-2">
                            <svg
                                class="w-4 h-4 shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                />
                            </svg>
                            {success}
                        </div>
                    )
                }

                <!-- Form -->
                <form method="POST" class="flex flex-col gap-5">
                    <div class="flex flex-col gap-1.5">
                        <label
                            for="email"
                            class="text-sm font-medium text-[var(--color-text-secondary)]"
                            >Email</label
                        >
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            placeholder="kamu@email.com"
                            class="w-full h-12 px-4 rounded-xl bg-[var(--color-bg)] border border-[var(--color-border)] text-[var(--color-text)] placeholder:text-[var(--color-muted)]/50 text-sm outline-none transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)]/20 focus:border-[var(--color-primary)]"
                        />
                    </div>

                    <button
                        type="submit"
                        class="w-full h-12 rounded-xl bg-[var(--color-primary)] text-[var(--color-bg)] font-bold text-sm hover:brightness-110 transition-all duration-200"
                    >
                        Kirim Link Reset
                    </button>
                </form>
            </div>

            <!-- Back to Login -->
            <p class="text-center text-sm text-[var(--color-muted)] mt-6">
                Ingat passwordnya?
                <a
                    href="/login"
                    class="text-[var(--color-primary)] font-medium hover:underline"
                    >Kembali ke login</a
                >
            </p>
        </div>
    </section>
</BaseLayout>
