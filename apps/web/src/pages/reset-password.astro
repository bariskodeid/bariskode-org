---
import BaseLayout from "../layouts/BaseLayout.astro";

const token = Astro.url.searchParams.get("token") ?? "";

let error = "";
let success = "";

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const resetToken = formData.get("token")?.toString().trim() ?? "";
        const password = formData.get("password")?.toString() ?? "";
        const passwordConfirm = formData.get("passwordConfirm")?.toString() ?? "";

        if (!resetToken) {
            error = "Token reset tidak ditemukan.";
        } else if (!password || password.length < 8) {
            error = "Password minimal 8 karakter.";
        } else if (password !== passwordConfirm) {
            error = "Konfirmasi password tidak sama.";
        } else {
            await Astro.locals.pb
                .collection("users")
                .confirmPasswordReset(resetToken, password, passwordConfirm);
            success = "Password berhasil direset. Silakan login dengan password baru.";
        }
    } catch {
        error = "Link reset tidak valid atau sudah kadaluarsa.";
    }
}
---

<BaseLayout
    title="Reset Password — Bariskode"
    description="Atur ulang password akun Bariskode kamu."
>
    <section class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12">
        <div class="w-full max-w-[460px] rounded-2xl border border-[var(--color-border)] p-8" style="background-color: var(--color-surface);">
            <h1 class="text-2xl font-bold text-[var(--color-text)] mb-2">Reset Password</h1>
            <p class="text-sm text-[var(--color-muted)] mb-6">
                Masukkan password baru untuk akunmu.
            </p>

            {error && <p class="mb-4 text-sm text-red-400">{error}</p>}
            {success && <p class="mb-4 text-sm text-[var(--color-primary)]">{success}</p>}

            <form method="POST" class="space-y-4">
                <input type="hidden" name="token" value={token} />

                <div>
                    <label for="password" class="text-sm text-[var(--color-text-secondary)]">Password baru</label>
                    <input
                        id="password"
                        name="password"
                        type="password"
                        minlength="8"
                        required
                        class="mt-1 w-full h-11 px-3 rounded-xl bg-[var(--color-bg)] border border-[var(--color-border)] text-[var(--color-text)] text-sm"
                    />
                </div>

                <div>
                    <label for="passwordConfirm" class="text-sm text-[var(--color-text-secondary)]">Konfirmasi password</label>
                    <input
                        id="passwordConfirm"
                        name="passwordConfirm"
                        type="password"
                        minlength="8"
                        required
                        class="mt-1 w-full h-11 px-3 rounded-xl bg-[var(--color-bg)] border border-[var(--color-border)] text-[var(--color-text)] text-sm"
                    />
                </div>

                <button
                    type="submit"
                    class="w-full h-11 rounded-xl text-sm font-bold"
                    style="background-color: var(--color-primary); color: var(--color-bg);"
                >
                    Simpan Password Baru
                </button>
            </form>

            <a href="/login" class="inline-block mt-5 text-sm text-[var(--color-primary)] hover:underline">Kembali ke login</a>
        </div>
    </section>
</BaseLayout>
