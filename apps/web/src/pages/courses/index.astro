---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CourseCard from "../../components/CourseCard.astro";
import type { Course, Category } from "../../types/index";

const pb = Astro.locals.pb;

// Fetch categories for filter
let categories: Category[] = [];
try {
  categories = await pb.collection("categories").getFullList<Category>({
    sort: "order",
  });
} catch {}

// Get filter params
const selectedCategory = Astro.url.searchParams.get("category") ?? "";
const selectedDifficulty = Astro.url.searchParams.get("difficulty") ?? "";
const searchQuery = Astro.url.searchParams.get("q") ?? "";

// Build PocketBase filter
const filters: string[] = ["status = 'published'"];
if (selectedCategory) {
  filters.push(`category.slug = '${selectedCategory}'`);
}
if (selectedDifficulty) {
  filters.push(`difficulty = '${selectedDifficulty}'`);
}
if (searchQuery) {
  filters.push(`(title ~ '${searchQuery}' || description ~ '${searchQuery}')`);
}

// Fetch courses
let courses: Course[] = [];
try {
  const result = await pb.collection("courses").getList<Course>(1, 50, {
    filter: filters.join(" && "),
    expand: "instructor,category",
  });
  courses = result.items;
} catch (e) {
  console.error("Error fetching courses:", e);
}

const difficulties = [
  { value: "beginner", label: "Pemula" },
  { value: "intermediate", label: "Menengah" },
  { value: "advanced", label: "Lanjutan" },
];
---

<BaseLayout title="Katalog Kursus — Bariskode" description="Jelajahi kursus pemrograman dan cybersecurity gratis.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-text)]">Katalog Kursus</h1>
      <p class="mt-2 text-[var(--color-muted)] max-w-xl">Pilih kursus sesuai minat dan levelmu. Semua gratis dan open source.</p>
    </div>

    <!-- Filters -->
    <div class="flex flex-col gap-4 mb-8">
      <!-- Search & Difficulty Row -->
      <div class="flex flex-col sm:flex-row gap-3 items-center w-full">
        <!-- Search -->
        <form method="GET" class="w-full sm:flex-1" id="filter-form">
          <input type="hidden" name="category" value={selectedCategory} />
          <input type="hidden" name="difficulty" value={selectedDifficulty} />
          <div class="relative w-full max-w-md">
            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" name="q" value={searchQuery} placeholder="Cari kursus..."
              class="w-full h-10 pl-10 pr-4 rounded-lg border border-[var(--color-border)] text-sm text-[var(--color-text)] placeholder:text-[var(--color-muted)] outline-none transition-all focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]"
              style="background-color: var(--color-surface);"
            />
          </div>
        </form>

        <!-- Difficulty Filter -->
        <div class="flex p-1 rounded-lg border border-[var(--color-border)] w-full sm:w-auto overflow-x-auto" style="background-color: var(--color-surface);">
          <a href={`/courses${selectedCategory ? `?category=${selectedCategory}` : ''}${searchQuery ? `${selectedCategory ? '&' : '?'}q=${searchQuery}` : ''}`}
             class:list={["flex-1 sm:flex-none inline-flex items-center justify-center h-8 px-4 rounded-md text-sm font-medium transition-all whitespace-nowrap",
               !selectedDifficulty ? "text-[var(--color-bg)]" : "text-[var(--color-muted)] hover:text-[var(--color-text)]"]}
             style={!selectedDifficulty ? "background-color: var(--color-text);" : ""}>
            Semua Level
          </a>
          {difficulties.map(({ value, label }) => {
            const isActive = selectedDifficulty === value;
            const href = `/courses?difficulty=${value}${selectedCategory ? `&category=${selectedCategory}` : ''}${searchQuery ? `&q=${searchQuery}` : ''}`;
            return (
              <a href={isActive ? `/courses${selectedCategory ? `?category=${selectedCategory}` : ''}${searchQuery ? `${selectedCategory ? '&' : '?'}q=${searchQuery}` : ''}` : href}
                 class:list={["flex-1 sm:flex-none inline-flex items-center justify-center h-8 px-4 rounded-md text-sm font-medium transition-all whitespace-nowrap",
                   isActive ? "text-[var(--color-bg)]" : "text-[var(--color-muted)] hover:text-[var(--color-text)]"]}
                 style={isActive ? "background-color: var(--color-text);" : ""}>
                {label}
              </a>
            );
          })}
        </div>
      </div>

      <!-- Category Filter -->
      <div class="flex flex-wrap gap-2 items-center mt-1">
        <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)] mr-2 hidden sm:block">Kategori</span>
        <a href={`/courses${selectedDifficulty ? `?difficulty=${selectedDifficulty}` : ''}${searchQuery ? `${selectedDifficulty ? '&' : '?'}q=${searchQuery}` : ''}`}
           class:list={["inline-flex items-center h-8 px-3 rounded-md border text-xs font-medium transition-all",
             !selectedCategory ? "border-[var(--color-primary)] text-[var(--color-primary)]" : "border-[var(--color-border)] text-[var(--color-muted)] hover:border-[var(--color-primary)]/50"]}
           style="background-color: var(--color-surface);">
          Semua
        </a>
        {categories.map((cat) => {
          const isActive = selectedCategory === cat.slug;
          const href = `/courses?category=${cat.slug}${selectedDifficulty ? `&difficulty=${selectedDifficulty}` : ''}${searchQuery ? `&q=${searchQuery}` : ''}`;
          return (
            <a href={isActive ? `/courses${selectedDifficulty ? `?difficulty=${selectedDifficulty}` : ''}${searchQuery ? `${selectedDifficulty ? '&' : '?'}q=${searchQuery}` : ''}` : href}
               class:list={["inline-flex items-center gap-1.5 h-8 px-3 rounded-md border text-xs font-medium transition-all",
                 isActive ? "border-[var(--color-primary)] text-[var(--color-primary)]" : "border-[var(--color-border)] text-[var(--color-muted)] hover:border-[var(--color-primary)]/50"]}
               style="background-color: var(--color-surface);">
              <span>{cat.icon}</span> <span>{cat.name}</span>
            </a>
          );
        })}
      </div>
    </div>

    <!-- Course Grid -->
    {courses.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {courses.map((course) => (
          <CourseCard course={course} />
        ))}
      </div>
    ) : (
      <!-- Empty State -->
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <div class="w-20 h-20 rounded-2xl flex items-center justify-center mb-6" style="background-color: var(--color-surface);">
          <svg class="w-10 h-10 text-[var(--color-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[var(--color-text)] mb-2">Belum ada kursus</h3>
        <p class="text-sm text-[var(--color-muted)] max-w-sm">
          {searchQuery || selectedCategory || selectedDifficulty
            ? "Tidak ada kursus yang cocok dengan filtermu. Coba ubah pencarian."
            : "Kursus sedang disiapkan. Stay tuned!"}
        </p>
        {(searchQuery || selectedCategory || selectedDifficulty) && (
          <a href="/courses" class="mt-4 inline-flex items-center h-10 px-5 rounded-xl text-sm font-medium text-[var(--color-bg)]" style="background-color: var(--color-primary);">
            Reset Filter
          </a>
        )}
      </div>
    )}
  </section>
</BaseLayout>
