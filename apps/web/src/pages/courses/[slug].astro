---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { Course, Module, Lesson } from "../../types/index";

const { slug } = Astro.params;
const { pb, user } = Astro.locals;

// Fetch the course
let course: Course | null = null;
let modules: (Module & { expand?: { lessons_via_module: Lesson[] } })[] = [];

try {
  course = await pb.collection("courses").getFirstListItem<Course>(
    `slug = '${slug}' && status = 'published'`,
    { expand: "instructor,category" }
  );
} catch {
  return Astro.redirect("/404");
}

if (!course) return Astro.redirect("/404");

// Fetch modules for this course
try {
  const moduleResult = await pb.collection("modules").getFullList<Module & { expand?: { lessons_via_module: Lesson[] } }>({
    filter: `course = '${course.id}'`,
    sort: "order",
    expand: "lessons_via_module",
  });
  modules = moduleResult;
} catch {}

// Flatten lessons for counting
const allLessons = modules.flatMap(
  (m) => (m.expand?.lessons_via_module ?? []).filter((l: Lesson) => l.status === "published")
);

// Fetch user progress if logged in
let progressMap: Record<string, boolean> = {};
if (user && allLessons.length > 0) {
  try {
    const lessonFilters = allLessons.map((l) => `lesson = '${l.id}'`).join(" || ");
    const progressRecords = await pb.collection("user_progress").getFullList({
      filter: `user = '${user.id}' && (${lessonFilters}) && status = 'completed'`,
    });
    progressMap = Object.fromEntries(progressRecords.map((p: any) => [p.lesson, true]));
  } catch {}
}

const totalLessons = allLessons.length;
const completedCount = Object.keys(progressMap).length;
const progressPercent = totalLessons > 0 ? Math.round((completedCount / totalLessons) * 100) : 0;
const firstLesson = allLessons[0];
const hasStarted = completedCount > 0;

// Find the next uncompleted lesson
const nextLesson = allLessons.find((l) => !progressMap[l.id]) ?? firstLesson;

const instructor = (course as any).expand?.instructor;
const category = (course as any).expand?.category;

const difficultyLabel: Record<string, string> = {
  beginner: "Pemula",
  intermediate: "Menengah",
  advanced: "Lanjutan",
};
const difficultyStyle: Record<string, string> = {
  beginner: "color: #22c55e; border-color: #22c55e;",
  intermediate: "color: #eab308; border-color: #eab308;",
  advanced: "color: #ef4444; border-color: #ef4444;",
};

const pbUrl = import.meta.env.PUBLIC_POCKETBASE_URL ?? "http://localhost:8090";
const thumbnailUrl = course.thumbnail
  ? `${pbUrl}/api/files/courses/${course.id}/${course.thumbnail}`
  : null;
---

<BaseLayout title={`${course.title} — Bariskode`} description={course.description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm">
      <ol class="flex items-center gap-2 text-[var(--color-muted)]">
        <li><a href="/courses" class="hover:text-[var(--color-primary)] transition-colors">Kursus</a></li>
        <li>/</li>
        {category && <li><a href={`/courses?category=${category.slug}`} class="hover:text-[var(--color-primary)] transition-colors">{category.name}</a></li>}
        {category && <li>/</li>}
        <li class="text-[var(--color-text)] truncate">{course.title}</li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- Hero -->
        {thumbnailUrl && (
          <img src={thumbnailUrl} alt={course.title}
               class="w-full h-64 object-cover rounded-2xl border border-[var(--color-border)] mb-6" />
        )}

        <div class="flex items-center gap-3 mb-4 flex-wrap">
          <span class="text-[11px] font-mono font-bold uppercase tracking-wider px-2.5 py-1 rounded-md border"
                style={difficultyStyle[course.difficulty]}>
            {difficultyLabel[course.difficulty] ?? course.difficulty}
          </span>
          {category && (
            <span class="text-xs text-[var(--color-muted)]">{category.icon} {category.name}</span>
          )}
          {course.tags?.map((tag: string) => (
            <span class="text-[11px] text-[var(--color-muted)] px-2 py-0.5 rounded-md border border-[var(--color-border)]"
                  style="background-color: var(--color-surface-alt);">
              {tag}
            </span>
          ))}
        </div>

        <h1 class="text-2xl sm:text-3xl font-bold text-[var(--color-text)] mb-3">{course.title}</h1>
        <p class="text-[var(--color-text-secondary)] leading-relaxed mb-8">{course.description}</p>

        <!-- Meta Row -->
        <div class="flex items-center gap-6 text-sm text-[var(--color-muted)] mb-8 pb-8 border-b border-[var(--color-border)]">
          {instructor && (
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold" style="background-color: var(--color-surface-alt); color: var(--color-primary);">
                {instructor.username?.charAt(0)?.toUpperCase()}
              </div>
              <span>{instructor.username}</span>
            </div>
          )}
          {(course.estimated_hours ?? 0) > 0 && (
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              {course.estimated_hours} jam
            </span>
          )}
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            {totalLessons} lesson
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            {course.enrolled_count} siswa
          </span>
        </div>

        <!-- Syllabus -->
        <h2 class="text-xl font-bold text-[var(--color-text)] mb-5">Silabus</h2>
        <div class="space-y-4">
          {modules.map((mod, modIndex) => {
            const lessons = (mod.expand?.lessons_via_module ?? [])
              .filter((l: Lesson) => l.status === "published")
              .sort((a: Lesson, b: Lesson) => a.order - b.order);
            return (
              <div class="rounded-xl border border-[var(--color-border)] overflow-hidden"
                   style="background-color: var(--color-surface);">
                <!-- Module Header -->
                <div class="px-5 py-4 border-b border-[var(--color-border)] flex items-center justify-between"
                     style="background-color: var(--color-surface-alt);">
                  <div class="flex items-center gap-3">
                    <span class="text-xs font-mono text-[var(--color-primary)] font-bold">M{modIndex + 1}</span>
                    <h3 class="font-semibold text-[var(--color-text)]">{mod.title}</h3>
                  </div>
                  <span class="text-xs text-[var(--color-muted)]">{lessons.length} lesson</span>
                </div>
                <!-- Lessons List -->
                <div class="divide-y divide-[var(--color-border)]">
                  {lessons.map((lesson: Lesson, lessonIndex: number) => {
                    const isCompleted = progressMap[lesson.id];
                    const typeIcon = lesson.type === "reading" ? "📖" : lesson.type === "video" ? "🎬" : lesson.type === "quiz" ? "❓" : "💻";
                    return (
                      <a href={`/learn/${lesson.id}`}
                         class:list={[
                           "flex items-center gap-4 px-5 py-3.5 transition-colors group",
                           isCompleted ? "hover:bg-[var(--color-surface-alt)]/30" : "hover:bg-[var(--color-surface-alt)]/50"
                         ]}>
                        <span class="flex items-center justify-center w-7 h-7 rounded-full text-xs font-mono shrink-0"
                              style={isCompleted
                                ? "background-color: var(--color-primary); color: var(--color-bg);"
                                : "border: 1px solid var(--color-border); color: var(--color-muted);"}>
                          {isCompleted ? "✓" : lessonIndex + 1}
                        </span>
                        <div class="flex-1 min-w-0 flex items-center gap-2">
                          <span class:list={[
                            "text-sm group-hover:text-[var(--color-primary)] transition-colors truncate block",
                            isCompleted ? "text-[var(--color-muted)] line-through opacity-70" : "text-[var(--color-text)]"
                          ]}>
                            {lesson.title}
                          </span>
                          {isCompleted && (
                            <span class="text-[10px] uppercase font-bold tracking-wider px-1.5 py-0.5 rounded border border-[var(--color-primary)]/30 text-[var(--color-primary)] opacity-80"
                                  style="background-color: var(--color-primary)/10;">
                              Selesai
                            </span>
                          )}
                        </div>
                        <span class="text-xs shrink-0">{typeIcon}</span>
                        {lesson.estimated_minutes && (
                          <span class="text-xs text-[var(--color-muted)] shrink-0">{lesson.estimated_minutes}m</span>
                        )}
                      </a>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </div>

        {modules.length === 0 && (
          <div class="text-center py-12">
            <p class="text-[var(--color-muted)]">Konten kursus sedang disiapkan.</p>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="sticky top-20 rounded-2xl border border-[var(--color-border)] p-6"
             style="background-color: var(--color-surface);">
          <!-- Progress -->
          {user && hasStarted && (
            <div class="mb-6">
              <div class="flex justify-between text-sm mb-2">
                <span class="text-[var(--color-muted)]">Progress</span>
                <span class="text-[var(--color-primary)] font-mono font-bold">{progressPercent}%</span>
              </div>
              <div class="h-2 rounded-full" style="background-color: var(--color-border);">
                <div class="h-full rounded-full transition-all duration-500" style={`width: ${progressPercent}%; background-color: var(--color-primary);`}></div>
              </div>
              <p class="text-xs text-[var(--color-muted)] mt-2">{completedCount}/{totalLessons} lesson selesai</p>
            </div>
          )}

          <!-- CTA Button -->
          {firstLesson ? (
            <a href={`/learn/${nextLesson?.id ?? firstLesson.id}`}
               class="flex items-center justify-center w-full h-12 rounded-xl text-sm font-bold transition-all hover:brightness-110"
               style="background-color: var(--color-primary); color: var(--color-bg);">
              {hasStarted ? "Lanjutkan Belajar" : "Mulai Belajar"}
            </a>
          ) : (
            <button disabled
                    class="w-full h-12 rounded-xl text-sm font-bold opacity-50 cursor-not-allowed"
                    style="background-color: var(--color-border); color: var(--color-muted);">
              Belum Ada Konten
            </button>
          )}

          <!-- Course Info -->
          <div class="mt-6 space-y-4">
            <div class="flex items-center justify-between text-sm">
              <span class="text-[var(--color-muted)]">Difficulty</span>
              <span class="font-medium" style={`color: ${course.difficulty === 'beginner' ? '#22c55e' : course.difficulty === 'intermediate' ? '#eab308' : '#ef4444'};`}>
                {difficultyLabel[course.difficulty]}
              </span>
            </div>
            <div class="flex items-center justify-between text-sm">
              <span class="text-[var(--color-muted)]">Total Lesson</span>
              <span class="text-[var(--color-text)]">{totalLessons}</span>
            </div>
            {(course.estimated_hours ?? 0) > 0 && (
              <div class="flex items-center justify-between text-sm">
                <span class="text-[var(--color-muted)]">Durasi</span>
                <span class="text-[var(--color-text)]">~{course.estimated_hours} jam</span>
              </div>
            )}
            <div class="flex items-center justify-between text-sm">
              <span class="text-[var(--color-muted)]">Siswa</span>
              <span class="text-[var(--color-text)]">{course.enrolled_count}</span>
            </div>
          </div>

          <!-- Back to catalog -->
          <a href="/courses" class="flex items-center justify-center gap-2 w-full h-11 mt-6 rounded-xl border border-[var(--color-border)] text-sm font-medium text-[var(--color-muted)] hover:border-[var(--color-primary)]/50 transition-all"
             style="background-color: var(--color-bg);">
            ← Kembali ke Katalog
          </a>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
