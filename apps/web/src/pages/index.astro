---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
	<!-- Hero Section -->
	<section class="relative overflow-hidden">
		<!-- Background effects -->
		<div class="absolute inset-0 -z-10">
			<div
				class="absolute top-1/4 left-1/4 w-96 h-96 bg-[var(--color-primary)] rounded-full opacity-[0.03] blur-3xl animate-float"
			>
			</div>
			<div
				class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-[var(--color-accent)] rounded-full opacity-[0.04] blur-3xl animate-float"
				style="animation-delay: -3s"
			>
			</div>
			<!-- Grid pattern -->
			<div
				class="absolute inset-0"
				style="background-image: radial-gradient(circle at 1px 1px, var(--color-border) 1px, transparent 0); background-size: 40px 40px; opacity: 0.3;"
			>
			</div>
		</div>

		<div
			class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-24 lg:pt-32 lg:pb-36"
		>
			<div class="text-center max-w-4xl mx-auto">
				<!-- Badge -->
				<div
					class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] mb-8 animate-fade-in"
				>
					<span
						class="w-2 h-2 rounded-full bg-[var(--color-primary)] animate-pulse-glow"
					></span>
					<span class="text-xs font-mono text-[var(--color-muted)]"
						>100% Open Source & Free</span
					>
				</div>

				<!-- Heading -->
				<h1
					class="text-4xl sm:text-5xl lg:text-7xl font-extrabold leading-tight tracking-tight mb-6 animate-slide-up"
				>
					<span class="text-[var(--color-text)]">Learn.</span>
					<span class="text-gradient"> Hack.</span>
					<span class="text-[var(--color-text)]"> Certify.</span>
				</h1>

				<p
					class="text-lg sm:text-xl text-[var(--color-text-secondary)] max-w-2xl mx-auto mb-10 animate-slide-up"
					style="animation-delay: 0.1s"
				>
					Platform pembelajaran pemrograman & cybersecurity open
					source. Dari dasar coding hingga CTF challenges — gratis,
					selamanya.
				</p>

				<!-- CTA Buttons -->
				<div
					class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up"
					style="animation-delay: 0.2s"
				>
					<a
						href="/register"
						class="inline-flex items-center px-8 py-3.5 text-base font-bold text-[var(--color-bg)] bg-[var(--color-primary)] rounded-xl hover:bg-[var(--color-primary-dim)] transition-all duration-300 glow-primary hover:scale-105"
					>
						Mulai Belajar Gratis
						<svg
							class="w-5 h-5 ml-2"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
						</svg>
					</a>
					<a
						href="/courses"
						class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-[var(--color-text)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all duration-300"
					>
						Lihat Kursus
					</a>
				</div>

				<!-- Stats -->
				<div
					class="grid grid-cols-3 gap-8 max-w-lg mx-auto mt-16 animate-slide-up"
					style="animation-delay: 0.3s"
				>
					<div class="text-center">
						<div
							class="text-2xl sm:text-3xl font-bold text-[var(--color-primary)] font-mono"
						>
							∞
						</div>
						<div class="text-xs text-[var(--color-muted)] mt-1">
							Akses Gratis
						</div>
					</div>
					<div class="text-center">
						<div
							class="text-2xl sm:text-3xl font-bold text-[var(--color-accent)] font-mono"
						>
							CTF
						</div>
						<div class="text-xs text-[var(--color-muted)] mt-1">
							Challenges
						</div>
					</div>
					<div class="text-center">
						<div
							class="text-2xl sm:text-3xl font-bold text-[var(--color-primary)] font-mono"
						>
							✓
						</div>
						<div class="text-xs text-[var(--color-muted)] mt-1">
							Sertifikat
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Features Section -->
	<section
		class="border-t border-[var(--color-border)] bg-[var(--color-surface)]"
	>
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
			<div class="text-center mb-16">
				<h2
					class="text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-4"
				>
					Semua yang kamu butuhkan untuk <span class="text-gradient"
						>level up</span
					>
				</h2>
				<p class="text-[var(--color-text-secondary)] max-w-xl mx-auto">
					Platform all-in-one untuk belajar coding dan cybersecurity,
					dari pemula hingga profesional.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				<!-- Feature Card 1 -->
				<div
					class="group p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] hover:border-[var(--color-primary)] transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-12 h-12 rounded-lg bg-[var(--color-primary-glow)] flex items-center justify-center mb-4 group-hover:glow-primary transition-all"
					>
						<span class="text-2xl">📚</span>
					</div>
					<h3
						class="text-lg font-semibold text-[var(--color-text)] mb-2"
					>
						Kursus Terstruktur
					</h3>
					<p
						class="text-sm text-[var(--color-muted)] leading-relaxed"
					>
						Jalur belajar dari dasar hingga advanced. Course →
						Module → Lesson dengan MDX content yang kaya.
					</p>
				</div>

				<!-- Feature Card 2 -->
				<div
					class="group p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] hover:border-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-12 h-12 rounded-lg bg-[rgba(124,58,237,0.15)] flex items-center justify-center mb-4 group-hover:glow-accent transition-all"
					>
						<span class="text-2xl">⌨️</span>
					</div>
					<h3
						class="text-lg font-semibold text-[var(--color-text)] mb-2"
					>
						Code Playground
					</h3>
					<p
						class="text-sm text-[var(--color-muted)] leading-relaxed"
					>
						Monaco Editor di browser. Tulis dan jalankan kode
						langsung — Python, JavaScript, Bash, dan lainnya.
					</p>
				</div>

				<!-- Feature Card 3 -->
				<div
					class="group p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] hover:border-[var(--color-primary)] transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-12 h-12 rounded-lg bg-[var(--color-primary-glow)] flex items-center justify-center mb-4 group-hover:glow-primary transition-all"
					>
						<span class="text-2xl">🏴</span>
					</div>
					<h3
						class="text-lg font-semibold text-[var(--color-text)] mb-2"
					>
						CTF Challenges
					</h3>
					<p
						class="text-sm text-[var(--color-muted)] leading-relaxed"
					>
						Web exploitation, cryptography, forensics, reverse
						engineering. Scoreboard real-time dan hint system.
					</p>
				</div>

				<!-- Feature Card 4 -->
				<div
					class="group p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] hover:border-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-12 h-12 rounded-lg bg-[rgba(124,58,237,0.15)] flex items-center justify-center mb-4 group-hover:glow-accent transition-all"
					>
						<span class="text-2xl">📝</span>
					</div>
					<h3
						class="text-lg font-semibold text-[var(--color-text)] mb-2"
					>
						Quiz & Assessment
					</h3>
					<p
						class="text-sm text-[var(--color-muted)] leading-relaxed"
					>
						Uji pemahamanmu dengan quiz interaktif. Multiple choice,
						true/false, dan code output questions.
					</p>
				</div>

				<!-- Feature Card 5 -->
				<div
					class="group p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] hover:border-[var(--color-primary)] transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-12 h-12 rounded-lg bg-[var(--color-primary-glow)] flex items-center justify-center mb-4 group-hover:glow-primary transition-all"
					>
						<span class="text-2xl">🏆</span>
					</div>
					<h3
						class="text-lg font-semibold text-[var(--color-text)] mb-2"
					>
						Sertifikat Terverifikasi
					</h3>
					<p
						class="text-sm text-[var(--color-muted)] leading-relaxed"
					>
						Selesaikan kursus, dapatkan sertifikat PDF dengan QR
						code. Verifikasi publik via URL unik.
					</p>
				</div>

				<!-- Feature Card 6 -->
				<div
					class="group p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] hover:border-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-12 h-12 rounded-lg bg-[rgba(124,58,237,0.15)] flex items-center justify-center mb-4 group-hover:glow-accent transition-all"
					>
						<span class="text-2xl">⚡</span>
					</div>
					<h3
						class="text-lg font-semibold text-[var(--color-text)] mb-2"
					>
						Gamification
					</h3>
					<p
						class="text-sm text-[var(--color-muted)] leading-relaxed"
					>
						XP, level, streak, badge, dan leaderboard. Belajar jadi
						lebih menyenangkan dan kompetitif.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="border-t border-[var(--color-border)]">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
			<div
				class="relative rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-12 lg:p-16 text-center overflow-hidden"
			>
				<!-- BG glow -->
				<div
					class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-32 bg-[var(--color-primary)] rounded-full opacity-[0.06] blur-3xl"
				>
				</div>

				<h2
					class="text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-4 relative z-10"
				>
					Siap untuk <span class="text-gradient">memulai?</span>
				</h2>
				<p
					class="text-[var(--color-text-secondary)] max-w-lg mx-auto mb-8 relative z-10"
				>
					Daftar gratis sekarang dan mulai perjalanan belajarmu. Tidak
					perlu kartu kredit, tidak ada biaya tersembunyi.
				</p>
				<a
					href="/register"
					class="relative z-10 inline-flex items-center px-8 py-3.5 text-base font-bold text-[var(--color-bg)] bg-[var(--color-primary)] rounded-xl hover:bg-[var(--color-primary-dim)] transition-all duration-300 glow-primary hover:scale-105"
				>
					Daftar Gratis Sekarang
					<svg
						class="w-5 h-5 ml-2"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
					</svg>
				</a>

				<p
					class="mt-6 text-xs text-[var(--color-muted)] font-mono relative z-10"
				>
					Open source · Self-hostable · MIT License
				</p>
			</div>
		</div>
	</section>
</BaseLayout>
