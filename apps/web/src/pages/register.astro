---
import BaseLayout from "../layouts/BaseLayout.astro";

if (Astro.locals.user) {
    return Astro.redirect("/dashboard");
}

let error = "";
let fieldErrors: Record<string, string> = {};

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const email = formData.get("email")?.toString().trim() ?? "";
        const username = formData.get("username")?.toString().trim() ?? "";
        const password = formData.get("password")?.toString() ?? "";
        const passwordConfirm =
            formData.get("passwordConfirm")?.toString() ?? "";

        if (!email) fieldErrors.email = "Email wajib diisi";
        if (!username || username.length < 3)
            fieldErrors.username = "Username minimal 3 karakter";
        if (username && !/^[a-zA-Z0-9_]+$/.test(username))
            fieldErrors.username =
                "Username hanya boleh huruf, angka, dan underscore";
        if (!password || password.length < 8)
            fieldErrors.password = "Password minimal 8 karakter";
        if (password !== passwordConfirm)
            fieldErrors.passwordConfirm = "Password tidak sama";

        if (Object.keys(fieldErrors).length === 0) {
            const pb = Astro.locals.pb;
            await pb.collection("users").create({
                email,
                username,
                password,
                passwordConfirm,
                role: "student",
                xp: 0,
                level: 1,
                streak_current: 0,
                streak_longest: 0,
            });

            // Send email verification (best effort).
            try {
                await pb.collection("users").requestVerification(email);
            } catch {
                // Ignore to avoid blocking registration.
            }

            await pb.collection("users").authWithPassword(email, password);

            const isVerified = Boolean((pb.authStore.record as { verified?: boolean } | null)?.verified);
            if (!isVerified) {
                pb.authStore.clear();
                return Astro.redirect(`/verify-email?email=${encodeURIComponent(email)}`);
            }

            return Astro.redirect("/dashboard");
        }
    } catch (e: any) {
        if (e?.response?.data) {
            const data = e.response.data;
            if (data.email) fieldErrors.email = "Email sudah digunakan";
            if (data.username)
                fieldErrors.username = "Username sudah digunakan";
        } else {
            error = "Terjadi kesalahan. Silakan coba lagi.";
        }
    }
}
---

<BaseLayout
    title="Daftar — Bariskode"
    description="Daftar akun gratis di Bariskode."
>
    <section
        class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12"
    >
        <div class="w-full max-w-[440px]">
            <!-- Card Container -->
            <div
                class="rounded-2xl border border-[var(--color-border)] backdrop-blur-xl p-12 shadow-2xl shadow-black/20"
                style="background-color: color-mix(in srgb, var(--color-surface) 90%, transparent);"
            >
                <!-- Header -->
                <div class="text-center mb-8">
                    <a
                        href="/"
                        class="inline-block text-[var(--color-primary)] font-mono font-bold text-xl hover:opacity-80 transition-opacity"
                        >&lt;bariskode/&gt;</a
                    >
                    <h1
                        class="text-2xl font-bold text-[var(--color-text)] mt-3"
                    >
                        Buat Akun Baru
                    </h1>
                    <p class="text-sm text-[var(--color-muted)] mt-1">
                        Gratis, selamanya. Mulai belajar sekarang.
                    </p>
                </div>

                <!-- OAuth Buttons -->
                <div class="flex flex-col gap-3 mb-6">
                    <a
                        href="/api/auth/oauth/github"
                        class="flex items-center justify-center gap-3 w-full h-12 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] font-medium text-sm hover:border-[var(--color-primary)]/50 hover:bg-[var(--color-bg)]/80 transition-all duration-200"
                    >
                        <svg
                            class="w-5 h-5 shrink-0"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                            ></path></svg
                        >
                        Daftar dengan GitHub
                    </a>
                    <a
                        href="/api/auth/oauth/google"
                        class="flex items-center justify-center gap-3 w-full h-12 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] font-medium text-sm hover:border-[var(--color-primary)]/50 hover:bg-[var(--color-bg)]/80 transition-all duration-200"
                    >
                        <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24"
                            ><path
                                fill="#4285F4"
                                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"
                            ></path><path
                                fill="#34A853"
                                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                            ></path><path
                                fill="#FBBC05"
                                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                            ></path><path
                                fill="#EA4335"
                                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                            ></path></svg
                        >
                        Daftar dengan Google
                    </a>
                </div>

                <!-- Divider -->
                <div class="flex items-center gap-4 mb-6">
                    <div class="flex-1 h-px bg-[var(--color-border)]"></div>
                    <span
                        class="text-xs text-[var(--color-muted)] font-mono uppercase tracking-widest"
                        >atau</span
                    >
                    <div class="flex-1 h-px bg-[var(--color-border)]"></div>
                </div>

                <!-- Error Banner -->
                {
                    error && (
                        <div class="mb-5 px-4 py-3 rounded-xl border border-red-500/30 bg-red-500/10 text-sm text-red-400 flex items-center gap-2">
                            <svg
                                class="w-4 h-4 shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                />
                            </svg>
                            {error}
                        </div>
                    )
                }

                <!-- Register Form -->
                <form method="POST" class="flex flex-col gap-5">
                    <!-- Email -->
                    <div class="flex flex-col gap-1.5">
                        <label
                            for="email"
                            class="text-sm font-medium text-[var(--color-text-secondary)]"
                            >Email</label
                        >
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            placeholder="kamu@email.com"
                            class:list={[
                                "w-full h-12 px-4 rounded-xl bg-[var(--color-bg)] border text-[var(--color-text)] placeholder:text-[var(--color-muted)]/50 text-sm outline-none transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)]/20 focus:border-[var(--color-primary)]",
                                fieldErrors.email
                                    ? "border-red-500"
                                    : "border-[var(--color-border)]",
                            ]}
                        />
                        {
                            fieldErrors.email && (
                                <p class="text-xs text-red-400">
                                    {fieldErrors.email}
                                </p>
                            )
                        }
                    </div>

                    <!-- Username -->
                    <div class="flex flex-col gap-1.5">
                        <label
                            for="username"
                            class="text-sm font-medium text-[var(--color-text-secondary)]"
                            >Username</label
                        >
                        <input
                            type="text"
                            id="username"
                            name="username"
                            required
                            minlength="3"
                            placeholder="hackerKu"
                            class:list={[
                                "w-full h-12 px-4 rounded-xl bg-[var(--color-bg)] border text-[var(--color-text)] placeholder:text-[var(--color-muted)]/50 text-sm font-mono outline-none transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)]/20 focus:border-[var(--color-primary)]",
                                fieldErrors.username
                                    ? "border-red-500"
                                    : "border-[var(--color-border)]",
                            ]}
                        />
                        {
                            fieldErrors.username && (
                                <p class="text-xs text-red-400">
                                    {fieldErrors.username}
                                </p>
                            )
                        }
                    </div>

                    <!-- Password -->
                    <div class="flex flex-col gap-1.5">
                        <label
                            for="password"
                            class="text-sm font-medium text-[var(--color-text-secondary)]"
                            >Password</label
                        >
                        <input
                            type="password"
                            id="password"
                            name="password"
                            required
                            minlength="8"
                            placeholder="Min. 8 karakter"
                            class:list={[
                                "w-full h-12 px-4 rounded-xl bg-[var(--color-bg)] border text-[var(--color-text)] placeholder:text-[var(--color-muted)]/50 text-sm outline-none transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)]/20 focus:border-[var(--color-primary)]",
                                fieldErrors.password
                                    ? "border-red-500"
                                    : "border-[var(--color-border)]",
                            ]}
                        />
                        {
                            fieldErrors.password && (
                                <p class="text-xs text-red-400">
                                    {fieldErrors.password}
                                </p>
                            )
                        }
                    </div>

                    <!-- Confirm Password -->
                    <div class="flex flex-col gap-1.5">
                        <label
                            for="passwordConfirm"
                            class="text-sm font-medium text-[var(--color-text-secondary)]"
                            >Konfirmasi Password</label
                        >
                        <input
                            type="password"
                            id="passwordConfirm"
                            name="passwordConfirm"
                            required
                            minlength="8"
                            placeholder="Ulangi password"
                            class:list={[
                                "w-full h-12 px-4 rounded-xl bg-[var(--color-bg)] border text-[var(--color-text)] placeholder:text-[var(--color-muted)]/50 text-sm outline-none transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)]/20 focus:border-[var(--color-primary)]",
                                fieldErrors.passwordConfirm
                                    ? "border-red-500"
                                    : "border-[var(--color-border)]",
                            ]}
                        />
                        {
                            fieldErrors.passwordConfirm && (
                                <p class="text-xs text-red-400">
                                    {fieldErrors.passwordConfirm}
                                </p>
                            )
                        }
                    </div>

                    <!-- Submit -->
                    <button
                        type="submit"
                        class="w-full h-12 rounded-xl bg-[var(--color-primary)] text-[var(--color-bg)] font-bold text-sm hover:brightness-110 transition-all duration-200 mt-1"
                    >
                        Buat Akun
                    </button>
                </form>
            </div>

            <!-- Login Link -->
            <p class="text-center text-sm text-[var(--color-muted)] mt-6">
                Sudah punya akun?
                <a
                    href="/login"
                    class="text-[var(--color-primary)] font-medium hover:underline"
                    >Masuk</a
                >
            </p>
        </div>
    </section>
</BaseLayout>
