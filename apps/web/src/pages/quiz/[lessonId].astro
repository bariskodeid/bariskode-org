---
import BaseLayout from "../../layouts/BaseLayout.astro";
import QuizEngine from "../../components/react/QuizEngine";
import { resolveLessonPageAccess } from "../../lib/lessonPageAccess";

const { lessonId } = Astro.params;
const { pb, user } = Astro.locals;
const access = await resolveLessonPageAccess(pb, user, lessonId, {
    currentPath: Astro.url.pathname,
    lockedMessage: "Complete the previous lesson before taking this quiz",
    requireQuiz: true,
});

if (access.kind === "redirect") {
    return Astro.redirect(access.location);
}

const lesson = access.context.lesson;
const courseSlug = access.context.course.slug ?? "";
const lessonTitle = lesson.title ?? "Quiz";
---

<BaseLayout
    title={`Quiz: ${lessonTitle} — Bariskode`}
    description={`Quiz untuk ${lessonTitle}`}
>
    <div class="min-h-[calc(100vh-4rem)] py-8">
        <QuizEngine
            client:only="react"
            lessonId={lessonId as string}
            lessonTitle={lessonTitle}
            passingScore={lesson.passing_score ?? 70}
            maxAttempts={lesson.max_attempts ?? 0}
            courseSlug={courseSlug}
        />
    </div>
</BaseLayout>
