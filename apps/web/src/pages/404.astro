---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="404 — Halaman Tidak Ditemukan"
    description="Halaman yang kamu cari tidak ada."
>
    <section
        class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12"
    >
        <div class="w-full max-w-lg text-center">
            <!-- 404 Number -->
            <div
                class="text-[120px] sm:text-[160px] font-black font-mono leading-none tracking-tight text-transparent bg-clip-text bg-gradient-to-b from-[var(--color-muted)] to-transparent select-none mb-4"
            >
                404
            </div>

            <h1
                class="text-2xl sm:text-3xl font-bold text-[var(--color-text)] mb-6"
            >
                Halaman Tidak Ditemukan
            </h1>

            <!-- Terminal Box -->
            <div
                class="rounded-2xl border border-[var(--color-border)] overflow-hidden mb-10 mx-auto max-w-md shadow-2xl shadow-black/30"
                style="background-color: var(--color-surface);"
            >
                <!-- Terminal Header -->
                <div
                    class="flex items-center gap-2 px-5 py-3 border-b border-[var(--color-border)]"
                    style="background-color: var(--color-bg);"
                >
                    <div
                        class="w-3 h-3 rounded-full"
                        style="background-color: #ef4444;"
                    >
                    </div>
                    <div
                        class="w-3 h-3 rounded-full"
                        style="background-color: #eab308;"
                    >
                    </div>
                    <div
                        class="w-3 h-3 rounded-full"
                        style="background-color: #22c55e;"
                    >
                    </div>
                    <span
                        class="ml-2 text-xs text-[var(--color-muted)] font-mono"
                        >terminal</span
                    >
                </div>
                <!-- Terminal Body -->
                <div
                    class="px-6 py-5 font-mono text-sm text-left leading-relaxed"
                >
                    <p class="text-[var(--color-muted)]">
                        <span class="text-[var(--color-primary)]">$</span> curl -s
                        <span class="text-[var(--color-accent)]"
                            >{Astro.url.pathname}</span
                        >
                    </p>
                    <p class="text-red-400 mt-2">
                        Error: ENOENT — no such file or directory
                    </p>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex items-center justify-center gap-4">
                <a
                    href="/"
                    class="inline-flex items-center justify-center h-12 px-8 text-sm font-bold text-[var(--color-bg)] bg-[var(--color-primary)] rounded-xl hover:brightness-110 transition-all duration-200"
                >
                    Ke Beranda
                </a>
                <a
                    href="/courses"
                    class="inline-flex items-center justify-center h-12 px-8 text-sm font-medium text-[var(--color-text)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-primary)] transition-all duration-200"
                    style="background-color: var(--color-surface);"
                >
                    Lihat Kursus
                </a>
            </div>
        </div>
    </section>
</BaseLayout>
