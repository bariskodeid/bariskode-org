---
import AdminLayout from '@components/admin/AdminLayout.astro';
import { resolveAdminRouteAccess } from '@lib/admin/adminAccess';

const access = resolveAdminRouteAccess({
  user: Astro.locals.user,
  currentPath: Astro.url.pathname,
});

if (access.kind === 'redirect') {
  return Astro.redirect(access.location);
}

const checklistItems = [
  'Shell admin sudah aktif dan dilindungi oleh middleware + helper admin access.',
  'Langkah berikutnya: tambahkan CRUD category, course, module, lesson, dan quiz question.',
  'Seluruh write path nanti harus lewat server-side API dengan validasi dan ownership checks.',
];
---

<AdminLayout
  title="Admin Overview"
  description="Ringkasan fase implementasi admin. Tahap ini menyiapkan shell, navigasi, dan kontrak akses sebelum CRUD konten dibangun."
  currentPath={Astro.url.pathname}
>
  <div class="grid gap-6 xl:grid-cols-[minmax(0,1.3fr)_minmax(0,0.9fr)]">
    <section class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-xs font-mono uppercase tracking-[0.2em] text-[var(--color-primary)]">
            Phase 0–1
          </p>
          <h2 class="mt-2 text-xl font-bold text-[var(--color-text)]">Admin shell siap dipakai</h2>
        </div>
        <span class="rounded-full border border-[var(--color-primary)] px-3 py-1 text-xs font-semibold text-[var(--color-primary)]">
          Foundation
        </span>
      </div>

      <ul class="mt-6 space-y-3">
        {checklistItems.map((item) => (
          <li class="flex gap-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-sm text-[var(--color-text)]">
            <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary)] text-xs font-bold text-[var(--color-bg)]">
              ✓
            </span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
      <p class="text-xs font-mono uppercase tracking-[0.2em] text-[var(--color-primary)]">
        Next milestones
      </p>
      <div class="mt-4 space-y-4">
        <div class="rounded-xl border border-[var(--color-border)] px-4 py-4">
          <h3 class="text-sm font-semibold text-[var(--color-text)]">Category management</h3>
          <p class="mt-1 text-sm text-[var(--color-muted)]">
            CRUD kategori untuk mengelompokkan course dan menjaga discovery tetap rapi.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] px-4 py-4">
          <h3 class="text-sm font-semibold text-[var(--color-text)]">Course structure editor</h3>
          <p class="mt-1 text-sm text-[var(--color-muted)]">
            Editor metadata course, module tree, lesson ordering, dan status publish.
          </p>
        </div>
      </div>
    </section>
  </div>
</AdminLayout>
