---
import BaseLayout from "../../layouts/BaseLayout.astro";

const { username } = Astro.params;
const { pb, user } = Astro.locals;

let profile: any = null;
let certificates: any[] = [];
let courseCount = 0;
let error = false;

try {
  profile = await pb.collection("users").getFirstListItem(`username = '${username}'`);
} catch {
  error = true;
}

if (profile) {
  const canViewCertificates = user?.id === profile.id || user?.role === "admin";

  if (canViewCertificates) {
    try {
      certificates = await pb.collection("certificates").getFullList({
        filter: `user = '${profile.id}' && is_valid = true`,
        expand: "course",
        sort: "-issued_at",
      });
    } catch {}
  }

  // Count unique completed courses
  try {
    const progress = await pb.collection("user_progress").getFullList({
      filter: `user = '${profile.id}' && status = 'completed'`,
      fields: "lesson",
    });
    // Rough count — count certificates as proxy for completed courses
    courseCount = certificates.length;
  } catch {}
}

const level = profile?.level ?? 1;
const xp = profile?.xp ?? 0;
const streakCurrent = profile?.streak_current ?? 0;
const streakLongest = profile?.streak_longest ?? 0;
const joinDate = profile?.created
  ? new Date(profile.created).toLocaleDateString("id-ID", { month: "long", year: "numeric" })
  : "";
---

<BaseLayout
  title={profile ? `${profile.username} — Bariskode` : "Profil Tidak Ditemukan — Bariskode"}
  description={profile ? `Profil ${profile.username} di Bariskode` : "Profil tidak ditemukan."}
>
  <div class="min-h-[calc(100vh-4rem)] px-4 py-12">
    {error || !profile ? (
      <div class="max-w-md mx-auto text-center py-16">
        <div class="text-5xl mb-4">👤</div>
        <h1 class="text-xl font-bold text-[var(--color-text)] mb-2">Profil Tidak Ditemukan</h1>
        <p class="text-sm text-[var(--color-muted)] mb-6">
          User "{username}" tidak ditemukan.
        </p>
        <a href="/"
           class="inline-flex items-center h-11 px-6 rounded-xl text-sm font-bold"
           style="background-color: var(--color-primary); color: var(--color-bg);">
          Kembali ke Beranda
        </a>
      </div>
    ) : (
      <div class="max-w-4xl mx-auto">
        <!-- Profile Header -->
        <div class="rounded-2xl border border-[var(--color-border)] overflow-hidden mb-8"
             style="background-color: var(--color-surface);">
          <!-- Banner -->
          <div class="h-28 relative"
               style="background: linear-gradient(135deg, var(--color-primary-glow), var(--color-surface-alt));">
          </div>

          <!-- Profile Info -->
          <div class="px-6 sm:px-8 pb-6 -mt-12">
            <div class="flex flex-col sm:flex-row sm:items-end gap-4">
              <!-- Avatar -->
              <div class="flex items-center justify-center w-24 h-24 rounded-2xl text-3xl font-black border-4"
                   style="background-color: var(--color-bg); border-color: var(--color-surface); color: var(--color-primary);">
                {profile.username.charAt(0).toUpperCase()}
              </div>

              <div class="flex-1">
                <h1 class="text-2xl font-bold text-[var(--color-text)]">{profile.username}</h1>
                {profile.bio && <p class="text-sm text-[var(--color-muted)] mt-1">{profile.bio}</p>}
                <div class="flex items-center gap-3 mt-2 text-xs text-[var(--color-muted)]">
                  <span>📅 Bergabung {joinDate}</span>
                  {profile.role === "instructor" && (
                    <span class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider"
                          style="background-color: var(--color-primary); color: var(--color-bg);">
                      Instructor
                    </span>
                  )}
                </div>
              </div>

              <!-- Social Links -->
              <div class="flex items-center gap-2 sm:self-center">
                {profile.github_url && (
                  <a href={profile.github_url} target="_blank" rel="noopener"
                     class="flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--color-border)] text-[var(--color-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-primary)]/50 transition-all"
                     style="background-color: var(--color-bg);">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                  </a>
                )}
                {profile.linkedin_url && (
                  <a href={profile.linkedin_url} target="_blank" rel="noopener"
                     class="flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--color-border)] text-[var(--color-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-primary)]/50 transition-all"
                     style="background-color: var(--color-bg);">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
          <div class="rounded-xl border border-[var(--color-border)] p-4 text-center" style="background-color: var(--color-surface);">
            <div class="text-2xl font-black text-[var(--color-primary)] font-mono">{level}</div>
            <div class="text-[10px] text-[var(--color-muted)] font-mono uppercase tracking-wider mt-1">Level</div>
          </div>
          <div class="rounded-xl border border-[var(--color-border)] p-4 text-center" style="background-color: var(--color-surface);">
            <div class="text-2xl font-black text-[var(--color-accent)] font-mono">{xp.toLocaleString()}</div>
            <div class="text-[10px] text-[var(--color-muted)] font-mono uppercase tracking-wider mt-1">Total XP</div>
          </div>
          <div class="rounded-xl border border-[var(--color-border)] p-4 text-center" style="background-color: var(--color-surface);">
            <div class="text-2xl font-black text-[var(--color-warning)] font-mono">{streakCurrent}🔥</div>
            <div class="text-[10px] text-[var(--color-muted)] font-mono uppercase tracking-wider mt-1">Streak</div>
          </div>
          <div class="rounded-xl border border-[var(--color-border)] p-4 text-center" style="background-color: var(--color-surface);">
            <div class="text-2xl font-black text-[var(--color-info)] font-mono">{certificates.length}</div>
            <div class="text-[10px] text-[var(--color-muted)] font-mono uppercase tracking-wider mt-1">Certificates</div>
          </div>
        </div>

        <!-- Certificates -->
        {certificates.length > 0 && (
          <section>
            <h2 class="text-lg font-bold text-[var(--color-text)] mb-4">🏆 Sertifikat</h2>
            <div class="space-y-3">
              {certificates.map((cert) => (
                <a href={`/verify/${cert.id}`}
                   class="flex items-center justify-between px-5 py-4 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)]/50 transition-all"
                   style="background-color: var(--color-surface);">
                  <div class="flex items-center gap-3">
                    <span class="flex items-center justify-center w-8 h-8 rounded-full text-sm"
                          style="background-color: var(--color-primary); color: var(--color-bg);">✓</span>
                    <div>
                      <p class="text-sm font-medium text-[var(--color-text)]">
                        {cert.expand?.course?.title ?? "Kursus"}
                      </p>
                      <p class="text-xs text-[var(--color-muted)]">
                        {new Date(cert.issued_at).toLocaleDateString("id-ID", { day: "numeric", month: "long", year: "numeric" })}
                      </p>
                    </div>
                  </div>
                  <span class="text-xs text-[var(--color-primary)] font-mono">Verify →</span>
                </a>
              ))}
            </div>
          </section>
        )}

        {certificates.length === 0 && (user?.id === profile.id || user?.role === "admin") && (
          <div class="text-center py-12 rounded-xl border border-[var(--color-border)]"
               style="background-color: var(--color-surface);">
            <div class="text-3xl mb-3">🎓</div>
            <p class="text-sm text-[var(--color-muted)]">Belum ada sertifikat.</p>
          </div>
        )}
      </div>
    )}
  </div>
</BaseLayout>
