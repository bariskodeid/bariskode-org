# PocketBase
PUBLIC_POCKETBASE_URL=http://localhost:8090

# Judge0 Code Execution (Phase 2)
JUDGE0_URL=http://localhost:2358

# Meilisearch (Phase 3)
MEILISEARCH_URL=http://localhost:7700
